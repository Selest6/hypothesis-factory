# Yandex AI Studio — embeddings + GPT
YANDEX_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# GPT (hypothesis generation)
YANDEX_MODEL=yandexgpt/latest
# YANDEX_COMPLETION_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion

# Embeddings (scripts/build_embeddings.py)
# YANDEX_EMBEDDING_DOC_MODEL=text-search-doc/latest
# YANDEX_EMBEDDING_QUERY_MODEL=text-search-query/latest

# Web search (optional, DuckDuckGo — без API-ключа)
# ENABLE_WEB_SEARCH=1

# OCR (scripts/ingest_ocr.py) — те же ключи; опционально:
# YANDEX_OCR_URL=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
